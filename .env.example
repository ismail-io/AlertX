# ─── AI ───────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Database ─────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/alerthub
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/alerthub
MONGO_URI=mongodb://localhost:27017/alerthub

# ─── Auth ─────────────────────────────────────────────────────
# Use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret

# ─── Admin ────────────────────────────────────────────────────
# Used by POST /api/seed-roles to assign defence/police roles
ADMIN_SECRET=change_this_admin_secret

# ─── App ──────────────────────────────────────────────────────
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development
